# Compatibilidad heredada:
# el proyecto ya usa `config/app_settings.json` como camino principal.
# Este archivo solo sirve si alguien prefiere overrides por variables de entorno.

# Backend FastAPI
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_FRONTEND_ORIGIN=http://127.0.0.1:4321

# ThingSpeak
THINGSPEAK_BASE_URL=https://api.thingspeak.com
THINGSPEAK_CHANNEL_ID=3353980
THINGSPEAK_READ_API_KEY=
THINGSPEAK_WRITE_API_KEY=
THINGSPEAK_ALLOW_LIVE_READS=true
THINGSPEAK_ALLOW_WRITE=false
THINGSPEAK_REQUEST_TIMEOUT_SECONDS=5.0
THINGSPEAK_MIN_SECONDS_BETWEEN_WRITES=16.0

# Frontend Astro
PUBLIC_BACKEND_URL=http://127.0.0.1:8000
